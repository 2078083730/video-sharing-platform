<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lcu.mapper.UserMapper">

    <select id="getUserInfo" resultType="user" parameterType="string">
        select * from s_user where email = #{value}
    </select>
    <select id="passwordLogin" resultType="user">
        select * from s_user where username =#{username} and password = md5(#{password})
    </select>
</mapper>